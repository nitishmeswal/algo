# Copy to `.env` for local overrides. Vite only exposes variables prefixed with `VITE_`.
# See: https://vitejs.dev/guide/env-and-mode.html

# App shell (optional; wire in code when you read import.meta.env)
# VITE_APP_TITLE=Prime Blotter

# Future: real OMS / blotter API
# VITE_API_BASE_URL=http://localhost:4000

# Blotter stream: set to use WebSocket instead of the in-browser mock (see README / vite proxy)
# VITE_BLOTTER_WS_URL=ws://127.0.0.1:8000/blotter-stream

# HTTP API origin for bootstrap `GET /orders` (omit to use same-origin `/orders`, e.g. Vite proxy in dev)
# VITE_BLOTTER_HTTP_URL=http://127.0.0.1:8000

# Server DB (used by server scripts, not exposed to browser)
# DATABASE_URL=postgres://flowdesk_app:change_me@127.0.0.1:5432/flowdesk
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECT_TIMEOUT_MS=5000

# Future: insights / AI gateway (never put real API keys in the frontend bundle)
# VITE_INSIGHTS_API_URL=http://localhost:4100
